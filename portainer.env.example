# Required
LITELLM_MASTER_KEY=sk-change-this-master-key
LITELLM_SALT_KEY=sk-change-this-salt-key
DATABASE_URL=postgresql://litellm:change-this-postgres-password@remote-postgres-host:5432/litellm?sslmode=require
REDIS_PASSWORD=change-this-redis-password

# Runtime
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest
LITELLM_PORT=4000
LITELLM_LOG=INFO
STORE_MODEL_IN_DB=False

# Resource limits. Defaults are tuned for a ~1 GB RAM / 1 vCPU instance with
# swap enabled. Raise these on larger hosts. Memory uses Compose v2 units
# (M = megabytes, G = gigabytes). REDIS_MAXMEMORY uses Redis units (mb, gb).
REDIS_MAXMEMORY=64mb
REDIS_MEM_LIMIT=128M
REDIS_MEM_RESERVATION=64M
REDIS_CPUS=0.25
LITELLM_MEM_LIMIT=700M
LITELLM_MEM_RESERVATION=400M
LITELLM_CPUS=0.75

# Config file mount.
# Git-based Portainer stacks can usually keep the default relative path.
# Web-editor stacks should use an absolute host path, for example:
# LITELLM_CONFIG_PATH=/opt/litellm/config.yaml
LITELLM_CONFIG_PATH=./litellm/config.yaml

# Direct providers
GROQ_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
OLLAMA_API_KEY=
OLLAMA_API_BASE=https://ollama.com/v1

# Gateway providers
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=http://localhost:4000
OR_APP_NAME=LiteLLM Simple Quality Gateway
VERCEL_AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_API_BASE=https://ai-gateway.vercel.sh/v1
LIGHTNING_AI_API_KEY=
LIGHTNING_AI_API_BASE=https://lightning.ai/api/v1

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_HOST=https://cloud.langfuse.com
