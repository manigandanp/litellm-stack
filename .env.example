# Copy this file to .env and replace every secret before starting the stack.
#
# Generate strong values with:
#   python -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"

# Compose profiles gate the bundled Postgres (local-db) and Redis (local-redis)
# services so the SAME command works everywhere:
#   - Local dev: set COMPOSE_PROFILES=local-db,local-redis so `up -d` starts
#     postgres + redis + litellm, and point DATABASE_URL/REDIS_HOST at the
#     `postgres`/`redis` services.
#   - Prod/CI deploy: DO NOT set COMPOSE_PROFILES so `up -d` starts only
#     litellm; postgres/redis are external/managed and reached via the remote
#     DATABASE_URL/REDIS_HOST. `--remove-orphans` cleans up any stray local
#     pg/redis containers from a prior run.
COMPOSE_PROFILES=local-db,local-redis

# LiteLLM proxy auth. Clients use this as their bearer token unless you create
# virtual keys from the LiteLLM admin API/UI.
LITELLM_MASTER_KEY=sk-change-this-master-key

# Used by LiteLLM to encrypt sensitive values in the database.
LITELLM_SALT_KEY=sk-change-this-salt-key

# Pin this to a tested image tag for production change control.
LITELLM_IMAGE=ghcr.io/berriai/litellm-database:main-latest
LITELLM_PORT=4000
LITELLM_LOG=INFO
STORE_MODEL_IN_DB=False

# Primary LiteLLM database.
#
# Local compose (bundled Postgres service): point at the `postgres` service on
# the compose network (NOT localhost, which inside the container means the
# container itself):
#   DATABASE_URL=postgresql://litellm:change-this-postgres-password@postgres:5432/litellm
#
# Prod (only the litellm service is deployed): use your remote Postgres URL.
# Keep passwords URL-encoded if they contain special characters. Prefer a
# direct Postgres URL for providers like Neon/Supabase because LiteLLM runs
# Prisma migrations at startup; PgBouncer/pooler URLs can break migrations.
DATABASE_URL=postgresql://litellm:change-this-postgres-password@postgres:5432/litellm

# Bundled local Postgres credentials (used by the `postgres` compose service,
# only active under the local-db profile — not started in prod).
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=litellm

# Redis for router state, auth cache, and optional response caching.
# Local compose (bundled Redis service): set REDIS_HOST=redis.
# Prod: point these at your remote Redis.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password
REDIS_MAXMEMORY=256mb

# Provider keys. Leave blank only while validating docker compose config.
GROQ_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
OLLAMA_API_KEY=
OLLAMA_API_BASE=https://ollama.com/v1

# Gateway/provider keys for the simple quality catalog. Vercel and Lightning can
# consume free credits or paid balance depending on your account.
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=http://localhost:4000
OR_APP_NAME=LiteLLM Simple Quality Gateway
VERCEL_AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_API_BASE=https://ai-gateway.vercel.sh/v1
LIGHTNING_AI_API_KEY=
LIGHTNING_AI_API_BASE=https://lightning.ai/api/v1

# Langfuse LLM observability. Use https://cloud.langfuse.com for EU, or
# https://us.cloud.langfuse.com for US.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_HOST=https://cloud.langfuse.com
